{
  "name": "frontend-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "export:openapi": "node scripts/export-openapi.mjs",
    "generate:api": "openapi-typescript openapi/openapi.json -o lib/api/generated/schema.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:members": "vitest run tests/unit/member-targets.test.ts",
    "test:products": "vitest run tests/unit/product-page.test.ts",
    "test:recipes": "vitest run tests/unit/recipe-search.test.ts",
    "test:calendar": "vitest run tests/unit/dates.test.ts",
    "test:schedule": "vitest run tests/unit/schedule-parse.test.ts tests/unit/schedule-overlap.test.ts",
    "test:expense": "vitest run tests/unit/expense-items.test.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@iconify/react": "^6.0.2",
    "@types/react-datepicker": "^6.2.0",
    "date-fns": "^4.4.0",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.1.0",
    "react-joyride": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@playwright/test": "^1.55.1",
    "vitest": "^3.2.4"
  }
}
