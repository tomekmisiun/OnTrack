# FastAPI backend URL (required for production builds)
NEXT_PUBLIC_API_URL=http://localhost:5001

# Optional Sentry (client errors; unset = disabled)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# Optional BFF mode — HttpOnly session cookies via Next.js Route Handlers (default off)
# NEXT_PUBLIC_BFF_ENABLED=1
