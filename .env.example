# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mealplanner

# Flask
FLASK_SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
FRONTEND_URL=http://localhost:3000
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback
AUTH_CODE_TTL_SECONDS=120
# FLASK_DEBUG=1  # tylko lokalnie bez .env — nigdy na produkcji

# Grafana
GF_SECURITY_ADMIN_PASSWORD=change-me

# External APIs (optional — features degrade gracefully without them)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GEMINI_API_KEY=
PEXELS_API_KEY=

# Scraper pipeline + in-app macro lookup (Products / nutrition API)
DEEPSEEK_API_KEY=

# --- Local Docker: Flask + FastAPI (MIG-002) ---
# Default: Flask on :5001 (frontend), FastAPI health on :8000
# FLASK_PUBLISH_PORT=5001
# BACKEND_PUBLISH_PORT=8000
#
# FastAPI on :5001 (curl localhost:5001/health → FastAPI), Flask on :5002:
# API_BACKEND=fastapi
# FLASK_PUBLISH_PORT=5002
# BACKEND_PUBLISH_PORT=5001
# GOOGLE_REDIRECT_URI=http://localhost:5002/api/auth/google/callback
#
# FastAPI backend (MIG-003+) — separate from Flask DATABASE_URL in Railway
# DATABASE_URL=postgresql+psycopg://user:change-me@localhost:5432/mealplanner
# TEST_DATABASE_URL=postgresql+psycopg://user:change-me@localhost:5432/ontrack_mig_test
# REDIS_URL=redis://localhost:6379/0

# --- Railway (Flask prod: ontrack-back) ---
# DATABASE_URL          ← auto from Railway Postgres plugin
# PORT                  ← auto from Railway
# FLASK_SECRET_KEY=     ← losowy token_hex(32)
# JWT_SECRET_KEY=       ← inny losowy token_hex(32)
# FRONTEND_URL=https://twoj-frontend.up.railway.app
# GOOGLE_REDIRECT_URI=https://twoj-backend.up.railway.app/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GEMINI_API_KEY=
# PEXELS_API_KEY=

# --- Railway (FastAPI staging: ontrack-back-fastapi-staging, MIG-014) ---
# Root Directory = repo root; config backend/railway.toml; Dockerfile.railway
# DATABASE_URL          ← CLONE Postgres only (ontrack-postgres-staging) — never live prod first
# JWT_SECRET_KEY=       ← same as Flask prod for login parity tests
# FLASK_SECRET_KEY=     ← same as Flask prod (OAuth session)
# REDIS_URL=            ← ontrack-redis-staging (worker service)
# See docs/backend-migration/RAILWAY_STAGING.md

# --- Railway (frontend service, build-time) ---
# REACT_APP_API_URL=https://twoj-backend.up.railway.app
# Deploy produkcji: Wait for CI w Railway — szczegóły w .github/DEPLOY.md
