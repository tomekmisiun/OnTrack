# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mealplanner

# Backend (FastAPI) — FLASK_SECRET_KEY name kept for OAuth session cookie compat
FLASK_SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
FRONTEND_URL=http://localhost:3000
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback
AUTH_CODE_TTL_SECONDS=120

# Grafana
GF_SECURITY_ADMIN_PASSWORD=change-me

# External APIs (optional — features degrade gracefully without them)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GEMINI_API_KEY=
PEXELS_API_KEY=

# Scraper pipeline + macro lookup
DEEPSEEK_API_KEY=

# --- Local Docker ---
# BACKEND_PUBLISH_PORT=5001   # API on :5001 (default), frontend REACT_APP_API_URL=http://localhost:5001
# BACKEND_DEBUG=1
# TEST_DATABASE_URL=postgresql+psycopg://user:change-me@localhost:5432/ontrack_mig_test

# --- Railway (FastAPI production: ontrack-back-fastapi) ---
# Root Directory = repo root; config backend/railway.prod.toml
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# JWT_SECRET_KEY= / FLASK_SECRET_KEY=  ← session + OAuth cookie signing
# GOOGLE_REDIRECT_URI=https://<fastapi-prod>/api/auth/google/callback
# See docs/backend-migration/PRODUCTION_CUTOVER.md

# --- Railway (FastAPI staging) ---
# See docs/backend-migration/RAILWAY_STAGING.md

# --- Railway (frontend: ontrackapp) ---
# REACT_APP_API_URL=https://<fastapi-prod-domain>
# Deploy: Wait for CI — .github/DEPLOY.md
