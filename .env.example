# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mealplanner

# Backend (FastAPI) — FLASK_SECRET_KEY name kept for OAuth session cookie compat
FLASK_SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
FRONTEND_URL=http://localhost:3000
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback
AUTH_CODE_TTL_SECONDS=120

# Grafana
GF_SECURITY_ADMIN_PASSWORD=change-me

# External APIs (optional — features degrade gracefully without them)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GEMINI_API_KEY=
PEXELS_API_KEY=

# Scraper pipeline + macro lookup
DEEPSEEK_API_KEY=

# --- Local Docker ---
# BACKEND_PUBLISH_PORT=5001   # API on :5001 (default)
# NEXT_PUBLIC_API_URL=http://localhost:5001   # Browser-facing API URL for frontend-next (Compose + local npm)
# NEXT_PUBLIC_BFF_ENABLED=1   # Optional HttpOnly cookie BFF — see docs/FRONTEND_NEXT_BFF.md
# BACKEND_DEBUG=1
# TEST_DATABASE_URL=postgresql+psycopg://user:change-me@localhost:5432/ontrack_mig_test

# --- Railway (FastAPI production: ontrack-back) ---
# Root Directory = backend; config backend/railway.toml
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# JWT_SECRET_KEY= / FLASK_SECRET_KEY=  ← session + OAuth cookie signing
# GOOGLE_REDIRECT_URI=https://<fastapi-prod>/api/auth/google/callback
# See docs/backend-migration/PRODUCTION_CUTOVER.md

# --- Railway (FastAPI staging) ---
# See docs/backend-migration/RAILWAY_STAGING.md

# --- Railway (frontend: ontrackapp) ---
# Root Directory = frontend-next; config frontend-next/railway.toml
# NEXT_PUBLIC_API_URL=https://<fastapi-prod-domain>   # build-time variable
# Deploy: Wait for CI — .github/DEPLOY.md

# --- Railway / Docker (frontend-next production image) ---
# docker build --build-arg NEXT_PUBLIC_API_URL=https://api.example.com -f frontend-next/Dockerfile --target runner frontend-next
